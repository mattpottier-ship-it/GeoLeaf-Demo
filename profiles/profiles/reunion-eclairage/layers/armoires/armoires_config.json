{
    "id": "armoires",
    "label": "Armoires électriques",
    "zIndex": 90,
    "geometry": "point",
    "interactiveShape": true,
    "showIconsOnMap": false,
    "data": {
        "directory": "data",
        "file": "armoires.geojson"
    },
    "styles": {
        "directory": "styles",
        "default": "defaut.json",
        "available": [
            { "id": "defaut", "label": "Défaut", "file": "defaut.json" }
        ]
    },
    "tooltip": {
        "mode": "hover",
        "fields": [
            { "type": "text", "field": "properties.id" }
        ]
    },
    "popup": {
        "enabled": true,
        "fields": [
            { "type": "text", "field": "properties.id", "variant": "title" },
            { "type": "text", "label": "Secteur", "field": "properties.secteur" },
            { "type": "text", "label": "Puissance totale (kW)", "field": "properties.puissance_kw" }
        ]
    }
}
