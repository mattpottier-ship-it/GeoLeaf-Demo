{
    "id": "volcans_actifs",
    "label": "Éruptions volcaniques actives",
    "tooltipMode": "hover",
    "zIndex": 70,
    "geometry": "point",
    "data": {
        "dataUrl": "https://www.gdacs.org/gdacsapi/api/events/geteventlist/SEARCH?eventtype=VO&alertlevel=Green;Orange;Red&limit=50",
        "directory": "data",
        "licence": "Libre — GDACS (Global Disaster Alerting Coordination System, JRC/EC)"
    },
    "styles": {
        "directory": "styles",
        "default": "defaut.json",
        "available": [
            {
                "id": "defaut",
                "label": "Défaut",
                "file": "defaut.json"
            }
        ]
    },
    "tooltip": {
        "mode": "hover",
        "fields": [
            { "field": "properties.name", "label": "Événement" },
            { "field": "properties.alertlevel", "label": "Niveau d'alerte" },
            { "field": "properties.country", "label": "Pays" },
            { "field": "properties.fromdate", "label": "Depuis" }
        ]
    },
    "table": {
        "enabled": true,
        "columns": [
            { "field": "properties.name", "label": "Événement", "sortable": true, "width": "40%" },
            { "field": "properties.country", "label": "Pays", "sortable": true, "width": "25%" },
            { "field": "properties.alertlevel", "label": "Alerte", "sortable": true, "width": "20%" },
            { "field": "properties.fromdate", "label": "Depuis", "sortable": true, "width": "15%" }
        ],
        "searchFields": ["properties.name", "properties.country"],
        "defaultSort": { "field": "properties.alertlevel", "order": "desc" }
    },
    "clustering": {
        "enabled": false
    }
}
