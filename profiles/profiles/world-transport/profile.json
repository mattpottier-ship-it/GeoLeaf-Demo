{
    "id": "world-transport",
    "label": "Transport mondial",
    "description": "Profil de démonstration GeoLeaf-JS — flux maritimes et aériens mondiaux. Sources open data (Natural Earth, OurAirports, OpenFlights, Zenodo). RT prévu : navires AIS (WebSocket) + avions (polling OpenSky OAuth2).",
    "version": "1.0.0",
    "map": {
        "center": [20, 10],
        "zoom": 2,
        "minZoom": 2,
        "maxZoom": 16
    },
    "Files": {
        "taxonomyFile": "taxonomy.json",
        "themesFile": "themes.json",
        "layersFile": "layers.json",
        "basemapsFile": "basemaps.json",
        "uiFile": "ui.json"
    },
    "performance": {
        "maxConcurrentLayers": 10,
        "layerLoadDelay": 200,
        "fitBoundsOnThemeChange": false
    },
    "clusteringConfig": {
        "enabled": true,
        "strategy": "by-layer",
        "maxClusterRadius": 60,
        "disableClusteringAtZoom": 5
    },
    "poiConfig": {
        "enabled": false
    },
    "storage": {
        "enableOfflineDetector": false,
        "enableServiceWorker": false,
        "cache": {
            "enableProfileCache": true,
            "enableTileCache": true
        }
    },
    "poiAddConfig": {
        "enabled": false
    }
}
