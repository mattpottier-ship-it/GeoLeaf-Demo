{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "geoleaf/layers",
    "title": "GeoLeaf Layers Index",
    "description": "layers.json — index of all layers loaded for a GeoLeaf profile.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "layers": {
            "type": "array",
            "description": "Individual layer references. Each entry points to a layer config file.",
            "items": {
                "type": "object",
                "required": ["id"],
                "additionalProperties": false,
                "properties": {
                    "id": { "type": "string", "description": "Unique layer identifier." },
                    "configFile": {
                        "type": "string",
                        "description": "Relative path to the layer config JSON file."
                    },
                    "layerManagerId": {
                        "type": "string",
                        "description": "Layer manager section this layer belongs to."
                    }
                }
            }
        },
        "layerTemplates": {
            "type": "array",
            "description": "Layer templates: one template expanded into N individual layer configs at runtime.",
            "items": {
                "type": "object",
                "required": ["templateId", "template", "instances"],
                "additionalProperties": false,
                "properties": {
                    "templateId": {
                        "type": "string",
                        "description": "Identifier for this template group."
                    },
                    "layerManagerId": {
                        "type": "string",
                        "description": "Layer manager section for all instances."
                    },
                    "template": {
                        "type": "object",
                        "description": "Base layer config shared by all instances.",
                        "properties": {
                            "zIndex": { "type": "number" },
                            "geometry": {
                                "type": "string",
                                "enum": ["polygon", "line", "point", "multipolygon"]
                            },
                            "data": {
                                "type": "object",
                                "properties": {
                                    "directory": { "type": "string" }
                                }
                            },
                            "styles": {
                                "type": "object",
                                "properties": {
                                    "directory": { "type": "string" },
                                    "default": { "type": "string" },
                                    "available": { "type": "array" }
                                }
                            },
                            "table": {
                                "type": "object",
                                "properties": {
                                    "enabled": { "type": "boolean" }
                                }
                            },
                            "clustering": {
                                "type": "object",
                                "properties": {
                                    "enabled": { "type": "boolean" },
                                    "maxClusterRadius": { "type": "number" },
                                    "disableClusteringAtZoom": { "type": "number" }
                                }
                            }
                        }
                    },
                    "instances": {
                        "type": "array",
                        "description": "One entry per expanded layer. Merged with template at runtime.",
                        "items": {
                            "type": "object",
                            "required": ["id", "label", "dataFile"],
                            "additionalProperties": true,
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "description": "Unique layer ID for this instance."
                                },
                                "label": {
                                    "type": "string",
                                    "description": "Display label for this instance."
                                },
                                "dataFile": {
                                    "type": "string",
                                    "description": "Data file name relative to the template's data.directory."
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
