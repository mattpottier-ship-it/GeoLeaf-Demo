{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "geoleaf/basemaps",
    "title": "GeoLeaf Basemaps",
    "description": "basemaps.json — basemap tile source definitions for a GeoLeaf profile.",
    "type": "object",
    "required": ["basemaps"],
    "additionalProperties": false,
    "properties": {
        "basemaps": {
            "type": "object",
            "description": "Map of basemap entries keyed by basemap ID.",
            "additionalProperties": {
                "$ref": "#/definitions/basemapEntry"
            }
        }
    },
    "definitions": {
        "basemapEntry": {
            "type": "object",
            "description": "A single basemap source definition.",
            "required": ["id"],
            "additionalProperties": true,
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Basemap ID (mirrors the key in the parent object)."
                },
                "label": { "type": "string", "description": "Display label." },
                "type": {
                    "type": "string",
                    "enum": ["tile", "maplibre"],
                    "description": "\"tile\" for raster, \"maplibre\" for vector tile (MapLibre GL style)."
                },
                "url": {
                    "type": "string",
                    "description": "Tile URL template with {s}, {z}, {x}, {y} placeholders."
                },
                "fallbackUrl": {
                    "type": "string",
                    "description": "Raster tile URL fallback when MapLibre GL is unavailable."
                },
                "style": {
                    "type": "string",
                    "description": "MapLibre GL style URL. Only for type: \"maplibre\"."
                },
                "tiles": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Explicit tile URL array for MapLibre raster sources. Overrides url + subdomains expansion."
                },
                "attribution": { "type": "string", "description": "HTML attribution string." },
                "minZoom": { "type": "number" },
                "maxZoom": { "type": "number" },
                "subdomains": {
                    "oneOf": [
                        { "type": "string" },
                        { "type": "array", "items": { "type": "string" } }
                    ],
                    "description": "Tile subdomains."
                },
                "tileSize": { "type": "number", "default": 256 },
                "defaultBasemap": {
                    "type": "boolean",
                    "description": "Set to true to make this the active basemap on startup."
                },
                "offline": {
                    "type": "boolean",
                    "description": "Whether this basemap supports offline tile caching."
                },
                "offlineBounds": {
                    "type": "object",
                    "description": "Geographic bounds for offline caching.",
                    "required": ["north", "south", "east", "west"],
                    "properties": {
                        "north": { "type": "number" },
                        "south": { "type": "number" },
                        "east": { "type": "number" },
                        "west": { "type": "number" }
                    }
                },
                "cacheMinZoom": { "type": "number" },
                "cacheMaxZoom": { "type": "number" },
                "terrain": {
                    "type": "object",
                    "description": "3D terrain / raster-dem configuration. Only valid when basemap type is \"maplibre\" or tiles-based.",
                    "required": ["enabled"],
                    "additionalProperties": false,
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "description": "Enables 3D terrain rendering for this basemap."
                        },
                        "demUrl": {
                            "type": "string",
                            "format": "uri",
                            "description": "URL template for the raster-dem tile source. Required when enabled is true."
                        },
                        "demEncoding": {
                            "type": "string",
                            "enum": ["terrarium", "mapbox"],
                            "default": "terrarium",
                            "description": "Tile encoding format for elevation data."
                        },
                        "exaggeration": {
                            "type": "number",
                            "minimum": 0.1,
                            "maximum": 10,
                            "default": 1.5,
                            "description": "Vertical exaggeration factor. Recommended range: 1.0–3.0."
                        },
                        "default3D": {
                            "type": "boolean",
                            "default": false,
                            "description": "When true, 3D terrain activates automatically when this basemap is selected."
                        },
                        "pitch": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 85,
                            "default": 45,
                            "description": "Initial camera pitch in degrees applied when 3D terrain is activated."
                        },
                        "bearing": {
                            "type": "number",
                            "minimum": -180,
                            "maximum": 180,
                            "default": 0,
                            "description": "Initial camera bearing in degrees applied when 3D terrain is activated."
                        }
                    }
                }
            }
        }
    }
}
