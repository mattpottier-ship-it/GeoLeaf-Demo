{
    "id": "itineraires_randonnee",
    "label": "Itinéraires de randonnée",
    "tooltipMode": "hover",
    "zIndex": 25,
    "interactiveShape": true,
    "geometry": "line",
    "data": {
        "dataUrl": "https://randoamazonie.guyane-parcnational.fr/api/v2/trek.kml",
        "format": "kml",
        "directory": "data",
        "licence": "Libre — Parc Amazonien de Guyane (randoamazonie.guyane-parcnational.fr)"
    },
    "styles": {
        "directory": "styles",
        "default": "defaut.json",
        "available": [
            {
                "id": "defaut",
                "label": "Défaut",
                "file": "defaut.json"
            }
        ]
    },
    "tooltip": {
        "mode": "hover",
        "fields": [
            { "field": "properties.name", "label": "Itinéraire" },
            { "field": "properties.description", "label": "Description" }
        ]
    },
    "table": {
        "enabled": true,
        "columns": [
            { "field": "properties.name", "label": "Itinéraire", "sortable": true, "width": "40%" },
            { "field": "properties.description", "label": "Description", "sortable": false, "width": "60%" }
        ],
        "searchFields": ["properties.name"],
        "defaultSort": { "field": "properties.name", "order": "asc" }
    },
    "clustering": {
        "enabled": false
    }
}
