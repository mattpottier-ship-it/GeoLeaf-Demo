{
    "id": "cyclones_actifs",
    "label": "Cyclones actifs",
    "tooltipMode": "hover",
    "zIndex": 75,
    "geometry": "point",
    "data": {
        "dataUrl": "https://www.gdacs.org/gdacsapi/api/events/geteventlist/SEARCH?eventtype=TC&alertlevel=Green;Orange;Red&limit=50",
        "directory": "data",
        "licence": "Libre — GDACS (Global Disaster Alerting Coordination System, JRC/EC)"
    },
    "styles": {
        "directory": "styles",
        "default": "defaut.json",
        "available": [
            {
                "id": "defaut",
                "label": "Défaut",
                "file": "defaut.json"
            }
        ]
    },
    "tooltip": {
        "mode": "hover",
        "fields": [
            { "field": "properties.name", "label": "Nom" },
            { "field": "properties.alertlevel", "label": "Niveau d'alerte" },
            { "field": "properties.country", "label": "Zone" },
            { "field": "properties.severitydata.severity", "label": "Vent max (km/h)" }
        ]
    },
    "table": {
        "enabled": true,
        "columns": [
            { "field": "properties.name", "label": "Nom", "sortable": true, "width": "30%" },
            { "field": "properties.alertlevel", "label": "Alerte", "sortable": true, "width": "20%" },
            { "field": "properties.country", "label": "Zone", "sortable": true, "width": "30%" },
            { "field": "properties.severitydata.severity", "label": "Vent (km/h)", "sortable": true, "width": "20%" }
        ],
        "searchFields": ["properties.name", "properties.country"],
        "defaultSort": { "field": "properties.alertlevel", "order": "desc" }
    },
    "clustering": {
        "enabled": false
    },
    "realtimeLayer": {
        "enabled": false,
        "description": "RT polling 6h — positions cyclones actifs via GDACS API. Données vides hors saison cyclonique.",
        "plugin": "@geoleaf-plugins/realtime-layer",
        "refreshInterval": 21600000
    }
}
