{
  "id": "france-urbanisme-btp",
  "label": "Urbanisme & BTP — Paris / Île-de-France",
  "version": "1.2.0",
  "description": "Profil GeoLeaf-JS — Bâtiments BD TOPO 3D (fill-extrusion), voirie et chantiers Paris. Centre Paris, zoom arrondissement.",
  "map": {
    "bounds": [
      [
        48.851,
        2.332
      ],
      [
        48.863,
        2.366
      ]
    ],
    "initialMaxZoom": 16,
    "padding": {
      "top": 40,
      "bottom": 120,
      "left": 40,
      "right": 40
    },
    "positionFixed": true,
    "boundsMargin": 0.7
  },
  "Files": {
    "taxonomyFile": "taxonomy.json",
    "themesFile": "themes.json",
    "layersFile": "layers.json",
    "basemapsFile": "basemaps.json",
    "uiFile": "ui.json"
  },
  "geocodingConfig": {
    "enabled": true,
    "provider": "addok",
    "bbox": [
      -5.2,
      41.3,
      9.6,
      51.1
    ]
  },
  "clustering": {
    "enabled": false
  },
  "storage": {
    "enableOfflineDetector": false,
    "enableServiceWorker": false
  },
  "bundleFile": "profile-bundle.json"
}