{
    "id": "stations_hydrometriques",
    "label": "Stations hydrométriques",
    "tooltipMode": "hover",
    "zIndex": 80,
    "geometry": "point",
    "data": {
        "dataUrl": "https://hubeau.eaufrance.fr/api/v1/hydrometrie/referentiel/stations?format=geojson&size=10000",
        "directory": "data",
        "licence": "Licence Ouverte v2.0 — Hub'Eau / EauFrance (hubeau.eaufrance.fr) — ⚠️ 403 Forbidden cross-origin (blocage backend confirmé nav. Chrome 2026-04-15) — proxy CF Worker prévu Sprint 2",
        "realtime": {
            "_comment": "Sprint 2 roadmap catalogue-demos v1.0.0. Polling 15 min sur Hub'Eau /observations_tr (GeoJSON natif — observations Vigicrues temps réel). URL distincte du référentiel statique (data.dataUrl). Si Hub'Eau renvoie 403 cross-origin runtime, fallbackUrl sert immédiatement un snapshot.",
            "enabled": true,
            "source": "polling",
            "url": "https://hubeau.eaufrance.fr/api/v1/hydrometrie/observations_tr?format=geojson&size=10000",
            "intervalMs": 900000,
            "decoder": "json",
            "updateMode": "merge",
            "idField": "code_station",
            "fallbackUrl": "data/stations_hydrometriques_snapshot.geojson"
        }
    },
    "styles": {
        "directory": "styles",
        "default": "defaut.json",
        "available": [
            {
                "id": "defaut",
                "label": "Par statut",
                "file": "defaut.json"
            }
        ]
    },
    "tooltip": {
        "mode": "hover",
        "fields": [
            { "field": "properties.libelle_station", "label": "Station" },
            { "field": "properties.libelle_cours_eau", "label": "Cours d'eau" },
            { "field": "properties.libelle_commune", "label": "Commune" },
            { "field": "properties.code_station", "label": "Code station" }
        ]
    },
    "table": {
        "enabled": true,
        "columns": [
            {
                "field": "properties.libelle_station",
                "label": "Station",
                "sortable": true,
                "width": "25%"
            },
            {
                "field": "properties.libelle_cours_eau",
                "label": "Cours d'eau",
                "sortable": true,
                "width": "25%"
            },
            {
                "field": "properties.libelle_commune",
                "label": "Commune",
                "sortable": true,
                "width": "20%"
            },
            {
                "field": "properties.code_station",
                "label": "Code",
                "sortable": true,
