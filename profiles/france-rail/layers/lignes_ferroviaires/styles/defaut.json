            "legend": { "label": "Ligne exploitée" }
        },
        {
            "when": { "field": "properties.statut", "operator": "==", "value": "Fermée" },
            "style": { "color": "#e76f51", "weight": 1.5, "opacity": 0.6, "dashArray": "4 3" },
            "legend": { "label": "Ligne fermée" }
        }
    ]
