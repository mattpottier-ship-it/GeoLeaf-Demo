{
    "id": "routes_aeriennes",
    "label": "Routes aériennes principales",
    "tooltipMode": "hover",
    "zIndex": 29,
    "geometry": "line",
    "data": {
        "dataUrl": "data/routes_aeriennes_snapshot.geojson",
        "directory": "data",
        "licence": "Snapshot démonstratif local — 8 routes aériennes indicatives (OpenFlights routes.geojson 404, routes.dat CSV non géolocalisé)"
    },
    "styles": {
        "directory": "styles",
        "default": "defaut.json",
        "available": [
            {
                "id": "defaut",
                "label": "Défaut",
                "file": "defaut.json"
            }
        ]
    },
    "tooltip": {
        "mode": "hover",
        "fields": [
            { "field": "properties.airline", "label": "Compagnie" },
            { "field": "properties.src_aprt", "label": "Départ" },
            { "field": "properties.dst_aprt", "label": "Arrivée" }
        ]
    },
    "table": {
        "enabled": false
    },
    "clustering": {
        "enabled": false
    },
    "realtimeLayer": {
        "enabled": false,
        "description": "RT prévu : avions en vol via polling OpenSky OAuth2 toutes les 10s — @geoleaf-plugins/realtime-layer. Les avions sont affichés en surcouche sur les routes statiques.",
        "plugin": "@geoleaf-plugins/realtime-layer",
        "dataUrl": "https://opensky-network.org/api/states/all",
        "refreshInterval": 10000,
        "auth": {
            "type": "oauth2",
            "connector": "@geoleaf/connector",
            "tokenKey": "opensky_token"
        }
    }
}
