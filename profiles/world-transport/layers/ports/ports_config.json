{
    "id": "ports",
    "label": "Ports maritimes majeurs",
    "tooltipMode": "hover",
    "zIndex": 75,
    "geometry": "point",
    "data": {
        "dataUrl": "https://raw.githubusercontent.com/nvkelso/natural-earth-vector/master/geojson/ne_10m_ports.geojson",
        "directory": "data",
        "licence": "Domaine public — Natural Earth ne_10m_ports (naturalearthdata.com) — HDX WPI non exposé en GeoJSON direct (ZIP only)",
        "realtime": {
            "_comment": "Sprint 2 roadmap catalogue-demos v1.0.0. enabled: false — positions AIS via WebSocket AISHub (wss://data.aishub.net/ws) non gérées par le plugin (GeoLeaf.Ws attend un canal broker interne). Bridge WS externe prévu Sprint 6 (PostGIS Réunion). En attendant, la couche reste servie par Natural Earth statique (data.dataUrl).",
            "enabled": false,
            "source": "websocket",
            "channel": "ais.aishub.global",
            "decoder": "json",
            "fallbackUrl": "https://raw.githubusercontent.com/nvkelso/natural-earth-vector/master/geojson/ne_10m_ports.geojson"
        }
    },
    "styles": {
        "directory": "styles",
        "default": "defaut.json",
        "available": [
            {
                "id": "defaut",
                "label": "Défaut",
                "file": "defaut.json"
            }
        ]
    },
    "tooltip": {
        "mode": "hover",
        "fields": [
            { "field": "properties.name", "label": "Port" },
            { "field": "properties.featurecla", "label": "Classe" },
            { "field": "properties.scalerank", "label": "Rang" }
        ]
    },
    "table": {
        "enabled": true,
        "columns": [
            { "field": "properties.name", "label": "Port", "sortable": true, "width": "50%" },
            {
                "field": "properties.featurecla",
                "label": "Classe",
                "sortable": true,
                "width": "20%"
            },
            { "field": "properties.scalerank", "label": "Rang", "sortable": true, "width": "15%" },
            {
                "field": "properties.natlscale",
                "label": "Échelle",
                "sortable": true,
                "width": "15%"
            }
        ],
        "searchFields": ["properties.name"],
        "defaultSort": { "field": "properties.scalerank", "order": "asc" }
    },
    "clustering": {
        "enabled": true,
        "maxClusterRadius": 50,
        "disableClusteringAtZoom": 4
    }
}
