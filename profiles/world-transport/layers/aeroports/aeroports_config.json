{
    "id": "aeroports",
    "label": "Aéroports internationaux",
    "tooltipMode": "hover",
    "zIndex": 74,
    "geometry": "point",
    "data": {
        "dataUrl": "https://davidmegginson.github.io/ourairports-data/airports.csv",
        "format": "csv",
        "mappingFile": "mapping.json",
        "directory": "data",
        "licence": "Domaine public — OurAirports (ourairports.com)",
        "realtime": {
            "_comment": "Sprint 2 roadmap catalogue-demos v1.0.0. enabled: false — OpenSky /states/all polling 10 s requiert OAuth2 (Bearer token) non supporté par le plugin. Extension 'auth' prévue v1.1. Fallback snapshot 50 vols servi pour la démo statique.",
            "enabled": false,
            "source": "polling",
            "url": "https://opensky-network.org/api/states/all",
            "intervalMs": 10000,
            "decoder": "json",
            "updateMode": "replace",
            "fallbackUrl": "data/opensky_states_snapshot.geojson"
        }
    },
    "styles": {
        "directory": "styles",
        "default": "defaut.json",
        "available": [
            {
                "id": "defaut",
                "label": "Défaut",
                "file": "defaut.json"
            }
        ]
    },
    "tooltip": {
        "mode": "hover",
        "fields": [
            { "field": "title", "label": "Aéroport" },
            { "field": "attributes.iata_code", "label": "IATA" },
            { "field": "attributes.country", "label": "Pays" },
            { "field": "attributes.type", "label": "Type" }
        ]
    },
    "table": {
        "enabled": true,
        "columns": [
            { "field": "title", "label": "Nom", "sortable": true, "width": "40%" },
            { "field": "attributes.iata_code", "label": "IATA", "sortable": true, "width": "10%" },
            { "field": "attributes.country", "label": "Pays", "sortable": true, "width": "25%" },
            { "field": "attributes.type", "label": "Type", "sortable": true, "width": "25%" }
        ],
        "searchFields": ["title", "attributes.iata_code", "attributes.country"],
        "defaultSort": { "field": "title", "order": "asc" }
    },
    "clustering": {
        "enabled": true,
        "maxClusterRadius": 60,
        "disableClusteringAtZoom": 5
    }
}
